{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Puppeteer Conversion Service",
		"description": "Тесты API сервиса скриншотов (puppeteer-test).\n\nПеред запуском: импортируйте окружение и задайте **bearer_token** = значение **ETERNAL_TOKEN** из `.env`.\n\nПосле **Create job** переменная **job_id** заполняется из ответа; затем вызывайте **Get job**.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{bearer_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000"
		},
		{
			"key": "bearer_token",
			"value": ""
		},
		{
			"key": "job_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Sync",
			"item": [
				{
					"name": "Convert (legacy JPEG)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com\",\n  \"format\": \"jpeg\"\n}"
						},
						"url": "{{base_url}}/api/v1/convert",
						"description": "Синхронный захват; ответ JSON с полем `url`."
					}
				},
				{
					"name": "Convert (PDF)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com\",\n  \"format\": \"pdf\"\n}"
						},
						"url": "{{base_url}}/api/v1/convert"
					}
				},
				{
					"name": "Convert (capture-ready)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com/dashboard/1\",\n  \"format\": \"jpeg\",\n  \"clip_to_element\": \"widget-1\",\n  \"wait_for_capture_ready\": true\n}"
						},
						"url": "{{base_url}}/api/v1/convert",
						"description": "Подставьте реальный URL дашборда и id виджета."
					}
				},
				{
					"name": "Convert and send (binary)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com\",\n  \"format\": \"jpeg\"\n}"
						},
						"url": "{{base_url}}/api/v1/convert-and-send",
						"description": "Ответ — бинарное тело (image/jpeg или application/pdf), не JSON."
					}
				}
			]
		},
		{
			"name": "Async jobs",
			"item": [
				{
					"name": "Create job",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    if (data && data.job_id) {",
									"        pm.collectionVariables.set('job_id', data.job_id);",
									"        pm.environment.set('job_id', data.job_id);",
									"        console.log('job_id сохранён:', data.job_id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com/dashboard/1\",\n  \"format\": \"jpeg\",\n  \"clip_to_element\": null,\n  \"wait_for_capture_ready\": true\n}"
						},
						"url": "{{base_url}}/api/v1/jobs",
						"description": "201 + `job_id`. Скрипт Tests сохраняет `job_id` в переменные коллекции и окружения."
					}
				},
				{
					"name": "Get job",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"url": "{{base_url}}/api/v1/jobs/{{job_id}}",
						"description": "Использует `{{job_id}}` после Create job. При пустом job_id подставьте UUID вручную."
					}
				}
			]
		}
	]
}
